# .env.example
# Copy this to .env and fill in your values:  cp .env.example .env
#
# NEVER commit your real .env — it is gitignored.
# Commit only this .env.example so other developers know what's needed.

# ── API ────────────────────────────────────────────────────────────────────────
# /api is proxied by Vite (dev) and Nginx (Docker) to the json-server backend
VITE_API_URL=/api

# ── Demo credentials (frontend-only auth simulation) ──────────────────────────
# In a real app these never exist here — auth happens on the server.
VITE_ADMIN_PASSWORD=your_admin_password_here
VITE_OPERATOR_PASSWORD=your_operator_password_here
